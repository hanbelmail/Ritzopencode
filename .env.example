# Next.js and browser connection
NEXT_PUBLIC_CONVEX_URL=
PUBLIC_APP_URL=http://localhost:3000

# Use the same value in Next.js and the Convex deployment.
# Run: npx convex env set SARA_SERVICE_KEY <value>
SARA_SERVICE_KEY=

# Existing ticket automation uses a separate key in Next.js and Convex.
# Run: npx convex env set N8N_API_KEY <value>
N8N_API_KEY=

# OpenAI runs only on the Next.js server.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Quo remains disabled in CRM settings until allowlist tests pass.
QUO_API_KEY=
QUO_FROM=
# Quo returns this whsec_ signing key when the message webhook is created.
QUO_WEBHOOK_SECRET=
# Development-only fallback when testing payloads locally.
QUO_WEBHOOK_TOKEN=

# Public staff registration is disabled unless explicitly enabled.
NEXT_PUBLIC_STAFF_REGISTRATION_ENABLED=false

# Set these only in Convex for an intentional, temporary staff bootstrap.
STAFF_REGISTRATION_ENABLED=false
STAFF_REGISTRATION_INVITE_CODE=
